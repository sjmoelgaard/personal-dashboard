# .env.example — kopiér til .env og udfyld
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dashboard

# Must match POSTGRES_USER, POSTGRES_PASSWORD and POSTGRES_DB above
DATABASE_URL=postgresql+asyncpg://dashboard:changeme@db:5432/dashboard

# Generér med: openssl rand -hex 32
JWT_SECRET=changeme

# Dit eget kodeord til login
OWNER_PASSWORD=changeme

NTFY_URL=http://ntfy:80
NTFY_TOPIC=mylife

ANTHROPIC_API_KEY=sk-ant-...

DOMAIN=mylife.smoelgaard.com

# iCal URL til kalender-sync (Google Calendar: Indstillinger → din kalender → "Hemmelig adresse i iCal-format")
ICAL_URL=
